import os
import subprocess

# Standard directory where NGINX looks for server configurations
NGINX_CONF_DIR = "/etc/nginx/conf.d"

def expose_app(app_name: str, internal_port: int, base_domain: str = "kushalcloud.local"):
    """
    Dynamically generates an NGINX reverse proxy block for a newly deployed container
    and reloads the web server gracefully.
    """
    config_content = f"""
server {{
    listen 80;
    server_name {app_name}.{base_domain};

    location / {{
        proxy_pass http://127.0.0.1:{internal_port};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }}
}}
"""
    conf_path = f"{NGINX_CONF_DIR}/{app_name}.conf"
    
    try:
        # 1. Write the new routing rule
        with open(conf_path, "w") as config_file:
            config_file.write(config_content)
            
        print(f"Created NGINX routing rule for {app_name}")
        
        # 2. Reload NGINX without dropping any current user traffic
        subprocess.run(["sudo", "systemctl", "reload", "nginx"], check=True)
        print(f"App {app_name} is now live at http://{app_name}.{base_domain}")
        
    except PermissionError:
        print("Error: Script needs sudo privileges to write to /etc/nginx/")
    except subprocess.CalledProcessError as e:
        print(f"NGINX reload failed: {e}")
